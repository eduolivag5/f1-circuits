---
const navLinks = [
  { name: 'Calendario', href: '/calendario' },
  { name: 'Pilotos', href: '/pilotos' },
  { name: 'Clasificación', href: '/clasificacion' },
  { name: 'Noticias', href: '/noticias' },
];
---

<nav class="fixed top-4 left-1/2 -translate-x-1/2 w-[95%] max-w-7xl z-50 font-f1">
  <div class="glass-container relative flex items-center justify-between px-6 py-3 md:py-4 rounded-2xl border border-white/10 shadow-2xl overflow-hidden">
    
    <div class="absolute -inset-full bg-gradient-to-r from-red-600/20 via-transparent to-red-600/20 animate-[spin_10s_linear_infinite] -z-10"></div>

    <a href="/" class="flex items-center group shrink-0">
      <div 
        id="logo-container" 
        class="flex items-center bg-red-600 h-10 px-3 rounded-lg transition-all duration-700 ease-in-out group-hover:skew-x-[-12deg] overflow-hidden shadow-[0_0_15px_rgba(225,6,0,0.3)]"
      >
        <span class="italic font-black text-white text-2xl leading-none translate-y-[-1px]">F</span>
        
        <div class="grid grid-cols-[0fr] transition-[grid-template-columns] duration-700 ease-in-out" id="logo-expansion">
          <div class="overflow-hidden">
            <span class="italic font-black text-white text-[10px] uppercase whitespace-nowrap opacity-0 transition-opacity duration-500 ml-0.5 mr-1 mt-2 block" id="logo-text">
              ormula
            </span>
          </div>
        </div>

        <span class="italic font-black text-white text-2xl leading-none translate-y-[-1px]">1</span>
      </div>
    </a>

    <div class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a href={link.href} class="text-[10px] font-bold text-white/70 hover:text-white hover:drop-shadow-[0_0_5px_#e10600] transition-all uppercase tracking-[0.2em]">
          {link.name}
        </a>
      ))}
    </div>

    <button id="menu-toggle" class="md:hidden text-white p-2">
      <div class="space-y-1.5">
        <span id="line1" class="block w-6 h-0.5 bg-white transition-all"></span>
        <span id="line2" class="block w-6 h-0.5 bg-white transition-all"></span>
      </div>
    </button>
  </div>

  <div id="mobile-menu" class="hidden absolute top-full left-0 right-0 mt-2 p-4 rounded-2xl glass-container border border-white/10 overflow-hidden">
    <div class="flex flex-col gap-4 font-f1">
      {navLinks.map(link => (
        <a href={link.href} class="text-lg font-bold text-white/90 border-b border-white/5 pb-2 italic uppercase">{link.name}</a>
      ))}
    </div>
  </div>
</nav>

<style>
  .glass-container {
    background: rgba(10, 10, 12, 0.85);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
  }

  /* Animación del Grid para inyectar el texto */
  .expanded-grid {
    grid-template-columns: 1fr !important;
    padding-right: 4px; /* Espacio antes del 1 */
  }

  .expanded-opacity {
    opacity: 1 !important;
  }

  /* Animación del icono de hamburguesa */
  .menu-open #line1 { transform: translateY(4px) rotate(45deg); }
  .menu-open #line2 { transform: translateY(-4px) rotate(-45deg); }
</style>

<script>
  function initNavbar() {
    const toggle = document.querySelector('#menu-toggle');
    const menu = document.querySelector('#mobile-menu');
    const expansion = document.querySelector('#logo-expansion');
    const text = document.querySelector('#logo-text');

    // Menú móvil
    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
      menu?.classList.toggle('flex');
      toggle.classList.toggle('menu-open');
    });

    // Bucle de animación del logo
    let isExpanded = false;
    function animate() {
      if (!expansion || !text) return;
      
      isExpanded = !isExpanded;
      if (isExpanded) {
        expansion.classList.add('expanded-grid');
        setTimeout(() => text.classList.add('expanded-opacity'), 100);
        setTimeout(animate, 5000); // Mantiene abierto 3s
      } else {
        text.classList.remove('expanded-opacity');
        setTimeout(() => {
          expansion.classList.remove('expanded-grid');
          setTimeout(animate, 20000); // Mantiene cerrado 6s
        }, 200);
      }
    }

    // Iniciar a los 2 segundos de carga
    setTimeout(animate, 2000);
  }

  document.addEventListener('astro:page-load', initNavbar);
</script>