---
// Navbar.astro
---
<div class="relative w-full h-full flex items-center justify-end"> <input type="checkbox" id="menu-drawer" class="peer hidden" />

  <label 
    for="menu-drawer" 
    id="menu-toggle" 
    class="relative z-[110] flex flex-col gap-1.5 md:hidden cursor-pointer p-2 opacity-0 pointer-events-none transition-all duration-300"
  >
    <span class="w-6 h-0.5 bg-white transition-all duration-300 origin-center"></span>
    <span class="w-6 h-0.5 bg-white transition-all duration-300"></span>
    <span class="w-6 h-0.5 bg-white transition-all duration-300 origin-center"></span>
  </label>

  <ul 
    id="nav-links"
    class="
      absolute md:relative top-full right-0 w-full md:w-auto 
      flex flex-col md:flex-row items-center md:items-center gap-6 md:gap-8 
      bg-[#0a0a0a]/95 md:bg-transparent backdrop-blur-3xl md:backdrop-blur-0 
      transition-all duration-500 z-[100]
      
      /* Oculto por defecto para esperar la animación del Hero */
      max-h-0 opacity-0 invisible pointer-events-none overflow-hidden
      
      /* Estado abierto en móvil (Checkbox Hack) */
      peer-checked:max-h-96 peer-checked:opacity-100 peer-checked:visible peer-checked:pointer-events-auto 
      peer-checked:py-8 peer-checked:mt-2
      
      /* Escritorio: La animación del Hero controlará el paso a visible */
      md:max-h-none md:static md:py-0 md:mt-0
    "
  >
    <li class="w-full text-center md:w-auto">
      <a href="#drivers" class="block py-2 text-white/70 hover:text-white text-[13px] md:text-[11px] uppercase font-bold tracking-[2px] transition-all">Drivers</a>
    </li>
    <li class="w-full text-center md:w-auto">
      <a href="#teams" class="block py-2 text-white/70 hover:text-white text-[13px] md:text-[11px] uppercase font-bold tracking-[2px] transition-all">Teams</a>
    </li>
    <li class="w-full text-center md:w-auto">
      <a href="#schedule" class="block py-2 text-white/70 hover:text-white text-[13px] md:text-[11px] uppercase font-bold tracking-[2px] transition-all">Schedule</a>
    </li>
  </ul>
</div>

<style>
  #menu-drawer:checked ~ label span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
  #menu-drawer:checked ~ label span:nth-child(2) { opacity: 0; transform: translateX(10px); }
  #menu-drawer:checked ~ label span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
</style>