---
import { REGULATIONS } from "../../data/data";
---
<section class="py-32 text-white overflow-hidden relative">
    <div class="absolute top-0 right-0 p-10 opacity-5 pointer-events-none">
        <span class="text-[200px] font-black italic uppercase leading-none">2026</span>
    </div>

    <div class="max-w-[1400px] mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center relative z-10">
        <div>
            <h2 class="text-7xl md:text-8xl font-black italic uppercase leading-[0.85] tracking-tighter mb-4">
                The New<br/><span class="text-f1-red">Era</span>
            </h2>
            <div class="w-24 h-2 bg-f1-red mb-8"></div>
            <p class="text-white/40 font-bold uppercase tracking-[4px] text-sm">Technical Regulations</p>
        </div>

        <div class="space-y-12">
            {REGULATIONS.map(r => (
                <div class="group border-l-2 border-white/10 hover:border-f1-red pl-8 transition-all duration-500">
                    <h4 class="font-black uppercase text-2xl tracking-tight group-hover:translate-x-2 transition-transform duration-300">
                        {r.title}
                    </h4>
                    <p class="text-white/50 italic mt-2 text-lg leading-relaxed max-w-md">
                        {r.desc}
                    </p>
                </div>
            ))}
        </div>
    </div>
</section>