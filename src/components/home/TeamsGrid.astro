---
import { TEAMS } from "../../data/data";
import Title from "../Title.astro";
---
<section>
    <div class="max-w-[1400px] mx-auto px-6">
        <Title title="Constructors" subtitle="The Competitors of the New Era" />
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
            {Object.values(TEAMS).map(t => (
                <div class="p-6 border border-white/5 bg-black/40 hover:scale-105 transition-transform">
                    <div class="h-1 w-full mb-4" style={`background-color: ${t.baseColor}`}></div>
                    <h4 class="font-black italic uppercase text-sm">{t.name}</h4>
                </div>
            ))}
        </div>
    </div>
</section>