---
interface Props {
  teamId: string;
  team: any;
  drivers: any[];
  index: number;
}

const { teamId, team, drivers, index } = Astro.props;

const formatName = (fullName: string) => {
    const [first, ...last] = fullName.split(' ');
    return { first, last: last.join(' ') };
};
---

<article 
    class="team-card group" 
    style={`--team-color: ${team.baseColor}; --delay: ${index * 0.05}s`}
>
    <div class="card-inner bg-[#111] border border-white/10 group-hover:border-white/20 transition-all duration-500 rounded-2xl overflow-hidden">
        
        <div class="relative p-6 border-b border-white/5">
            <div class="relative z-10 flex justify-between items-start">
                <div>
                    <p class="text-[10px] font-mono text-white/40 mb-1">RANK #{team.rank2025}</p>
                    <h2 class="text-2xl font-black uppercase italic text-white group-hover:translate-x-1 transition-transform duration-500 leading-tight">
                        {team.name}
                    </h2>
                </div>
                <img 
                    src={`/teams/${teamId}.svg`} 
                    alt={`${team.name} logo`}
                    class="w-12 h-12 object-contain team-logo transition-transform duration-500 group-hover:scale-110"
                    loading="lazy"
                />
            </div>
            <div class="absolute right-3 bottom-1 text-6xl font-black italic text-white/[0.03] pointer-events-none group-hover:text-white/[0.08] transition-all duration-700 uppercase leading-none">
                {team.name.slice(0, 3)}
            </div>
        </div>

        <div class="p-6 space-y-10">
            {drivers.map((driver) => {
                const { first, last } = formatName(driver.name);
                return (
                    /* 1. Envolvemos en un <a> con la ruta dinámica */
                    <a href={`/drivers/${driver.id}`} class="driver-entry group/driver block no-underline">
                        <div class="flex justify-between items-end mb-4">
                            <div class="flex items-baseline gap-3">
                                <span class="text-4xl font-black italic leading-none text-transparent number-stroke">
                                    {driver.number}
                                </span>
                                <h3 
                                    class="text-xl font-bold uppercase tracking-tight text-white/90 group-hover/driver:text-white transition-colors"
                                    transition:name={`driver-name-${driver.id}`}
                                >
                                    <span class="text-sm font-medium opacity-70 block mb-0.5">{first}</span>
                                    <span class="text-2xl font-black block -mt-1">{last}</span>
                                </h3>
                            </div>
                            <div class="text-right">
                                <span class="text-[10px] font-mono text-white/30 block mb-1">{driver.country}</span>
                                <div class="h-[2px] w-8 ml-auto bg-[var(--team-color)] opacity-80 group-hover/driver:w-12 transition-all duration-500" />
                            </div>
                        </div>

                        <div class="flex gap-6 mt-4 opacity-60 group-hover/driver:opacity-100 transition-opacity duration-500">
                            {['Wins', 'Podiums', 'Titles'].map((stat) => (
                                <div class="stat">
                                    <span class="block text-[8px] uppercase tracking-widest text-white/40">{stat}</span>
                                    <span class={`font-bold text-xs ${stat === 'Titles' && driver.titles > 0 ? 'text-[var(--team-color)]' : 'text-white'}`}>
                                        {driver[stat.toLowerCase() as keyof typeof driver]}
                                    </span>
                                </div>
                            ))}
                        </div>
                    </a>
                );
            })}
        </div>
        
        <div class="h-1.5 w-full bg-white/5">
            <div class="h-full w-full opacity-20 group-hover:opacity-100 transition-all duration-700 ease-out bg-[var(--team-color)]" />
        </div>
    </div>
</article>

<style>
    .team-card {
        will-change: transform, opacity;
        animation: reveal 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) var(--delay) both;
    }

    .card-inner {
        backface-visibility: hidden;
        transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.4s ease;
    }

    .team-card:hover .card-inner {
        transform: translateY(-5px) translateZ(0);
        box-shadow: 0 20px 40px -15px rgba(0,0,0,0.7);
    }

    .team-logo {
        filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.1));
    }

    .team-card:hover .team-logo {
        filter: drop-shadow(0 0 12px var(--team-color));
    }

    .number-stroke {
        -webkit-text-stroke: 1.5px var(--team-color);
        filter: drop-shadow(0 0 8px var(--team-color));
        transition: transform 0.4s ease, filter 0.4s ease;
    }

    .team-card:hover .number-stroke {
        filter: drop-shadow(0 0 15px var(--team-color));
        transform: scale(1.05) translateZ(0);
    }

    @keyframes reveal {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @media (prefers-reduced-motion: reduce) {
        .team-card { animation: none; opacity: 1; }
        .card-inner { transition: none; }
    }
</style>