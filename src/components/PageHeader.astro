---
interface Props {
  title: string;
  highlightedWord?: string; // Palabra en rojo
  subtitle?: string;
}

const { 
  title, 
  highlightedWord = "Feed", 
  subtitle = "Temporada 2026 - Era Eléctrica" 
} = Astro.props;
---

<header class="mb-12 border-l-4 border-red-600 pl-6">
  <h1 class="text-5xl md:text-7xl font-black uppercase italic tracking-tighter">
    {title} <span class="text-red-600">{highlightedWord}</span>
  </h1>
  <p class="text-white/40 uppercase tracking-[0.4em] text-xs mt-2">
    {subtitle}
  </p>
</header>