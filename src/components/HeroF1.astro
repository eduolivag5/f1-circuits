---
// Aquí podrías recibir props si quisieras personalizar el título
---

<header class="relative h-screen w-full bg-black flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 opacity-10">
        <div class="absolute top-1/4 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-f1-red to-transparent animate-trace-slow"></div>
        <div class="absolute top-3/4 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-white to-transparent animate-trace-fast"></div>
    </div>

    <div class="relative z-10 w-full max-w-4xl px-4 flex flex-col items-center">
        <div class="relative w-full group">
            <div class="car-svg-container mx-auto">
                <object 
                    type="image/svg+xml" 
                    data="/f1_car.svg" 
                    class="w-full h-auto f1-car-wireframe">
                </object>
            </div>

            <div class="absolute inset-0 bg-f1-red/10 blur-[120px] rounded-full animate-pulse pointer-events-none"></div>
        </div>

        <div class="text-center mt-12 animate-fade-in-delayed">
            <h1 class="text-white font-black italic uppercase tracking-[1.2em] text-xl md:text-2xl">
                Formula 1 <span class="text-f1-red">2026</span>
            </h1>
            <div class="h-[2px] w-24 bg-f1-red mx-auto mt-4 animate-expand-width"></div>
        </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-30">
        <div class="w-[1px] h-16 bg-gradient-to-b from-f1-red via-white to-transparent animate-scroll-line"></div>
    </div>
</header>

<style is:global>
    /* IMPORTANTE: Para animar los trazos, tu f1_car.svg debe tener paths con 'stroke' */
    
    .f1-car-wireframe {
        filter: drop-shadow(0 0 8px rgba(255, 24, 1, 0.4));
    }

    /* Animación de trazado (solo funciona si el SVG es inline o se manipula vía JS)
       Como lo cargamos por object, aplicamos un efecto de barrido visual: */
    
    .car-svg-container {
        mask-image: linear-gradient(to right, black var(--p), transparent var(--p));
        -webkit-mask-image: linear-gradient(to right, black var(--p), transparent var(--p));
        animation: reveal-car 3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes reveal-car {
        0% { --p: 0%; opacity: 0; filter: brightness(3); }
        100% { --p: 100%; opacity: 1; filter: brightness(1); }
    }

    @property --p {
        syntax: '<percentage>';
        inherits: false;
        initial-value: 0%;
    }

    /* Líneas de velocidad de fondo */
    @keyframes trace {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }
    .animate-trace-slow { animation: trace 8s linear infinite; }
    .animate-trace-fast { animation: trace 4s linear infinite; }

    .animate-fade-in-delayed {
        opacity: 0;
        animation: fadeIn 1s ease-out 2s forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes expand-width {
        from { width: 0; }
        to { width: 96px; }
    }
    .animate-expand-width { animation: expand-width 1.5s ease-out 2.5s forwards; }

    @keyframes scroll-line {
        0% { transform: scaleY(0); transform-origin: top; }
        50% { transform: scaleY(1); transform-origin: top; }
        51% { transform: scaleY(1); transform-origin: bottom; }
        100% { transform: scaleY(0); transform-origin: bottom; }
    }
    .animate-scroll-line { animation: scroll-line 2s infinite; }
</style>