---
import Layout from '../../layouts/Layout.astro';
import { CIRCUITS } from '../../data/data';

export async function getStaticPaths() {
    return CIRCUITS.map((circuit) => ({
        params: { id: circuit.id },
        props: { circuit },
    }));
}

const { circuit } = Astro.props;

const specsArray = [
    { 
        label: 'First GP', 
        value: circuit.specs.firstGP, 
        svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>` 
    },
    { 
        label: 'Laps', 
        value: circuit.specs.laps, 
        svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>` 
    },
    { 
        label: 'Length', 
        value: circuit.specs.length, 
        svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7v14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2Z"/><path d="M7 12h10"/><path d="M7 8h10"/><path d="M7 16h10"/></svg>` 
    },
    { 
        label: 'Distance', 
        value: circuit.specs.distance, 
        svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>` 
    },
    { 
        label: 'Record', 
        value: circuit.specs.record, 
        svg: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>` 
    },
];
---

<Layout title={`${circuit.name}`}>
    <main>
        
        <header class="max-w-7xl mx-auto px-6 pb-12">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div class="space-y-4">
                    <div class="flex items-center gap-4" transition:animate="fade">
                        <span class="bg-f1-red text-white px-2 py-1 rounded-sm font-black italic text-[10px] tracking-widest">ROUND {circuit.round}</span>
                        <span class="text-zinc-500 text-xs font-bold uppercase tracking-[0.2em]">{circuit.location}</span>
                    </div>
                    <h1 
                        class="text-5xl md:text-7xl font-black italic uppercase tracking-tighter leading-tight"
                        transition:name={`title-${circuit.id}`}
                    >
                        {circuit.name}
                    </h1>
                    <p class="text-2xl font-mono text-zinc-400">
                        {circuit.date}
                    </p>
                </div>

                <div class="flex justify-center lg:justify-end">
                    <img 
                        src={`/Circuits/nuevos/${circuit.id}.svg`}
                        alt={circuit.name}
                        class="h-64 md:h-80 w-auto object-contain brightness-0 invert drop-shadow-[0_0_30px_rgba(225,6,0,0.2)]"
                        transition:name={`track-${circuit.id}`}
                    />
                </div>
            </div>
        </header>

        <section class="max-w-7xl mx-auto px-6 py-12 border-t border-white/5">
            <h2 class="text-f1-red font-black italic uppercase tracking-[0.3em] text-[10px] mb-8 flex items-center gap-4">
                TECHNICAL DATA <span class="h-[2px] flex-1 bg-red-800"></span>
            </h2>
            <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
                {specsArray.map(spec => (
                    <div class="bg-zinc-900/40 border border-white/5 p-6 rounded-2xl flex flex-col items-start group hover:border-f1-red/30 transition-all duration-300">
                        <span class="text-f1-red mb-3 opacity-80 transition-transform text-f1-red" set:html={spec.svg} />
                        <span class="text-[10px] text-zinc-500 uppercase font-bold tracking-widest mb-1">{spec.label}</span>
                        <span class="text-lg font-black italic tracking-tight uppercase text-white/90">
                            {spec.value}
                        </span>
                    </div>
                ))}
            </div>
        </section>

        <section class="max-w-7xl mx-auto px-6 py-12 border-t border-white/5">
            <div class="space-y-16">
                <div class="w-full" transition:animate="slide">
                    <h2 class="text-f1-red font-black italic uppercase tracking-[0.3em] text-[10px] mb-8 flex items-center gap-4">
                        THE CIRCUIT EXPERIENCE <span class="h-[2px] flex-1 bg-red-800"></span>
                    </h2>
                    <p class="max-w-3xl text-lg md:text-xl leading-relaxed font-light italic text-zinc-400 border-l-2 border-f1-red pl-6">
                        {circuit.description}
                    </p>
                </div>

                <div class="space-y-8">
                    <h2 class="text-f1-red font-black italic uppercase tracking-[0.3em] text-[10px] flex items-center gap-4">
                        THE CIRCUIT DETAILS <span class="h-[2px] flex-1 bg-red-800"></span>
                    </h2>
                    <img 
                        src={`/Circuits/details/${circuit.id}.avif`} 
                        alt={`Panorama of ${circuit.name}`}
                        class="w-full h-full object-cover"
                    />
                </div>
            </div>
        </section>

    </main>
</Layout>