---
import Layout from '../../layouts/Layout.astro';
import { DRIVERS, TEAMS } from '../../data/data';

export async function getStaticPaths() {
  return DRIVERS.map((driver) => ({
    params: { id: driver.id },
    props: { driver },
  }));
}

const { driver } = Astro.props;
const team = TEAMS[driver.teamId];

const [firstName, ...lastNameParts] = driver.name.split(' ');
const lastName = lastNameParts.join(' ');

// Lógica para la bandera (asumiendo que driver.country es el nombre del país o código)
// Si tienes un mapeo de ISO codes sería ideal, si no, usamos el nombre.
const countryCode = driver.country || driver.country.slice(0, 2).toLowerCase(); 

const statCards = [
  { 
    label: "World Titles", 
    value: driver.titles, 
    icon: `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>` 
  },
  { 
    label: "GP Victories", 
    value: driver.wins, 
    icon: `<path d="M4 15l4-4 4 4m0-6l4 4 4-4"/>` 
  },
  { 
    label: "Podiums", 
    value: driver.podiums, 
    icon: `<path d="M8 21h8M12 17V3m-4 4h8"/>` 
  },
  { 
    label: "Total Entries", 
    value: driver.entries, 
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>` 
  }
];
---

<Layout title={`${driver.name}`}>
  <main class="min-h-screen pb-20 px-6 text-white bg-[#030303]">
    <div class="max-w-6xl mx-auto">
      
      <header class="relative flex flex-col md:flex-row items-center gap-10 py-10 border-b border-white/5">
        <div class="absolute -top-10 -left-10 w-64 h-64 blur-[80px] opacity-10 rounded-full" style={`background-color: ${team.baseColor}`}></div>

        <div class="relative z-10" transition:name={`driver-image-${driver.id}`}>
          <div 
            class="w-32 h-32 md:w-40 md:h-40 rounded-full p-[2px]"
            style={`background: linear-gradient(135deg, ${team.baseColor}88, transparent, ${team.baseColor}88)`}
          >
            <div class="w-full h-full rounded-full overflow-hidden bg-[#0a0a0a] relative border-2 border-black/50">
               <img 
                src={`/drivers/${driver.id}.png`} 
                alt={driver.name}
                class="w-full h-full object-cover object-top scale-110 mt-2"
              />
            </div>
          </div>
          <div 
            class="absolute -top-1 -right-1 w-10 h-10 rounded-full flex items-center justify-center text-sm font-black italic border border-white/10 backdrop-blur-2xl shadow-xl"
            style={`background-color: ${team.baseColor}; color: white;`}
          >
            {driver.number}
          </div>
        </div>

        <div class="flex-1 text-center md:text-left space-y-3 z-10">
          
          <h1 
            class="text-4xl md:text-6xl font-black uppercase italic tracking-tighter leading-none"
            transition:name={`driver-name-${driver.id}`}
          >
            <span class="text-white/20 not-italic font-light text-xl md:text-2xl block tracking-widest mb-1">{firstName}</span>
            <span style={`color: ${team.baseColor}`}>{lastName}</span>
          </h1>
          
          <div class="flex items-center justify-center md:justify-start gap-3">
            <img src={`/teams/${driver.teamId}.svg`} class="h-6 w-6 opacity-80" alt="" />
            <h2 class="text-xs text-left font-bold tracking-[0.4em] uppercase opacity-40 italic">{team.fullName}</h2>
          </div>
          
          <div class="flex flex-wrap items-center justify-center md:justify-start gap-3 pt-2">
             <div class="flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/5">
                <img 
                  src={`https://flagicons.lipis.dev/flags/4x3/${driver.country.toLowerCase()}.svg`} 
                  class="w-4 h-auto rounded-sm object-cover" 
                  alt={driver.country}
                />
                <span class="text-[10px] font-bold tracking-[0.3em] uppercase opacity-60">
                  {driver.country.slice(0, 3)}
                </span>
             </div>
             
             <span class="text-[10px] font-bold tracking-[0.3em] uppercase py-1 px-3 rounded-full bg-white/5 border border-white/5" style={`color: ${team.baseColor}`}>Rank 2025: P{driver.rank2025}</span>
          </div>
        </div>
      </header>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-12">
        {statCards.map(stat => (
          <div class="relative p-6 rounded-2xl border border-white/5 bg-zinc-900/30 backdrop-blur-xl overflow-hidden">
            <div class="relative z-10 flex flex-col gap-4">
              <div 
                class="w-10 h-10 rounded-xl flex items-center justify-center" 
                style={`background-color: ${team.baseColor}15; color: ${team.baseColor}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={stat.icon} />
              </div>
              <div>
                <p class="text-[9px] font-black uppercase tracking-[0.3em] text-white/30 mb-1">{stat.label}</p>
                <p class="text-4xl font-mono font-black italic leading-none">{stat.value}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <div class="mt-8 p-10 rounded-[2.5rem] border border-white/5 bg-[#080808]/50 backdrop-blur-md relative overflow-hidden">
        <div class="absolute -bottom-10 -right-10 text-[15rem] font-black italic text-white/[0.02] select-none leading-none">
          {driver.number}
        </div>
        <div class="relative z-10 grid grid-cols-1 lg:grid-cols-3 gap-12 items-center">
            <div class="flex flex-col items-center justify-center">
                <div class="relative flex items-center justify-center">
                    <svg class="w-40 h-40 transform -rotate-90">
                        <circle cx="80" cy="80" r="75" stroke="rgba(255,255,255,0.02)" stroke-width="6" fill="transparent"/>
                        <circle cx="80" cy="80" r="75" stroke={team.baseColor} stroke-width="8" fill="transparent" 
                            stroke-dasharray="471" 
                            stroke-dashoffset={471 - (471 * Math.min(driver.points, 100)) / 100} 
                        />
                    </svg>
                    <div class="absolute flex flex-col items-center">
                        <span class="text-5xl font-black italic font-mono leading-none">{driver.points}</span>
                        <span class="text-[8px] font-black text-white/20 uppercase tracking-[0.4em] mt-2">Points</span>
                    </div>
                </div>
            </div>
            <div class="lg:col-span-2 space-y-8">
                <div class="flex items-center gap-4">
                    <span class="h-[1px] w-12" style={`background-color: ${team.baseColor}`}></span>
                    <h3 class="text-[10px] font-black uppercase tracking-[0.6em] text-white/30 italic">2026 Telemetry Data</h3>
                </div>
                <div class="grid grid-cols-3 gap-6">
                    <div class="space-y-1">
                        <p class="text-[8px] font-bold text-white/10 uppercase tracking-widest">Status</p>
                        <p class="text-lg font-black italic uppercase text-white/70">Active</p>
                    </div>
                    <div class="space-y-1">
                        <p class="text-[8px] font-bold text-white/10 uppercase tracking-widest">Efficiency</p>
                        <p class="text-lg font-black italic uppercase text-white/70">94.2%</p>
                    </div>
                    <div class="space-y-1">
                        <p class="text-[8px] font-bold text-white/10 uppercase tracking-widest">Reliability</p>
                        <p class="text-lg font-black italic uppercase" style={`color: ${team.baseColor}`}>High</p>
                    </div>
                </div>
            </div>
        </div>
      </div>
    </div>
  </main>
</Layout>