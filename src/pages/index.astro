---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

const circuits = [
    { round: 1, id: 'australia', name: 'Australian GP', location: 'Melbourne', date: '06-08 MAR' },
    { round: 2, id: 'china', name: 'Chinese GP', location: 'Shanghai', date: '13-15 MAR' },
    { round: 3, id: 'japan', name: 'Japanese GP', location: 'Suzuka', date: '27-29 MAR' },
    { round: 4, id: 'bahrain', name: 'Bahrain GP', location: 'Sakhir', date: '10-12 APR' },
    { round: 6, id: 'miami', name: 'Miami GP', location: 'Miami', date: '01-03 MAY' },
    { round: 7, id: 'canada', name: 'Canadian GP', location: 'Montreal', date: '22-24 MAY' },
    { round: 8, id: 'monaco', name: 'Monaco GP', location: 'Monte Carlo', date: '05-07 JUN' },
    { round: 9, id: 'barcelona', name: 'Barcelona GP', location: 'Barcelona', date: '12-14 JUN' },
    { round: 10, id: 'austria', name: 'Austrian GP', location: 'Spielberg', date: '26-28 JUN' },
    { round: 11, id: 'great-britain', name: 'British GP', location: 'Silverstone', date: '03-05 JUL' },
    { round: 12, id: 'belgium', name: 'Belgian GP', location: 'Spa', date: '17-19 JUL' },
    { round: 13, id: 'hungary', name: 'Hungarian GP', location: 'Budapest', date: '24-26 JUL' },
    { round: 14, id: 'netherlands', name: 'Dutch GP', location: 'Zandvoort', date: '21-23 AUG' },
    { round: 15, id: 'italy', name: 'Italian GP', location: 'Monza', date: '04-06 SEP' },
    { round: 17, id: 'azerbaijan', name: 'Azerbaijan GP', location: 'Baku', date: '24-26 SEP' },
    { round: 18, id: 'singapore', name: 'Singapore GP', location: 'Marina Bay', date: '09-11 OCT' },
    { round: 19, id: 'austin', name: 'United States GP', location: 'Austin', date: '23-25 OCT' },
    { round: 20, id: 'mexico', name: 'Mexico City GP', location: 'Mexico', date: '30 OCT - 01 NOV' },
    { round: 21, id: 'brazil', name: 'São Paulo GP', location: 'Interlagos', date: '06-08 NOV' },
    { round: 22, id: 'las-vegas', name: 'Las Vegas GP', location: 'Las Vegas', date: '19-21 NOV' },
    { round: 24, id: 'abu-dhabi', name: 'Abu Dhabi GP', location: 'Yas Marina', date: '04-06 DEC' },
];
---

<Layout title="F1 2026 Calendar">
    <main class="max-w-7xl mx-auto px-4 py-12">
        <div class="flex flex-col md:flex-row justify-between items-start mb-16 gap-6 border-l-8 border-f1-red p-8 rounded-r-3xl bg-gradient-to-r from-white/5 to-transparent backdrop-blur-md">
            <div>
                <h1 class="text-4xl md:text-8xl font-black italic uppercase tracking-tighter leading-none font-f1-bold">
                    F1 <span class="text-f1-red">2026</span><br/>Schedule
                </h1>
                <p class="text-zinc-400 font-bold mt-4 uppercase text-sm">The New Era of Racing</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            {circuits.map((circuit, index) => {
                const isPriority = index < 3;
                
                return (
                    <a 
                        href={`/circuit/${circuit.id}`} 
                        data-astro-prefetch="hover"
                        class="circuit-card group bg-zinc-900/40 border border-white/10 hover:border-f1-red/50 transition-all duration-500 relative flex flex-col rounded-[2.5rem] shadow-2xl hover:shadow-f1-red/10"
                    >
                        <div class="absolute top-6 right-6 bg-white/10 backdrop-blur-md px-4 py-1.5 rounded-full font-black italic group-hover:bg-f1-red group-hover:text-white transition-all duration-300 text-[10px] z-20 border border-white/5">
                            ROUND {circuit.round}
                        </div>

                        <div class="p-10">
                            <p class="text-f1-red font-bold text-xs mb-3 tracking-[0.2em] font-f1-bold">{circuit.date}</p>
                            <h2 
                                class="text-2xl font-black uppercase italic tracking-tight mb-1 font-f1-bold group-hover:text-white transition-colors"
                                transition:name={`title-${circuit.id}`}
                            >
                                {circuit.name}
                            </h2>
                            <p class="text-zinc-500 text-xs uppercase font-bold tracking-widest mb-10">{circuit.location}</p>

                            <div class="h-44 flex items-center justify-center relative">
                                <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-10 group-hover:opacity-20 transition-all duration-700">
                                    <span class="text-white text-9xl font-black italic uppercase select-none font-f1-bold scale-110">
                                        {circuit.id.substring(0, 3)}
                                    </span>
                                </div>
                                
                                <img 
                                    src={`/Circuits/${circuit.id}.svg`}
                                    alt={`Layout of ${circuit.name}`}
                                    loading={isPriority ? "eager" : "lazy"}
                                    decoding="async"
                                    class="h-full w-auto object-contain z-10 will-change-transform transition-all duration-700 cubic-bezier group-hover:scale-110 group-hover:filter group-hover:drop-shadow-[0_10px_30px_rgba(225,6,0,0.3)]" 
                                    transition:name={`track-${circuit.id}`}
                                />
                            </div>
                        </div>

                        <div class="mt-auto mx-4 mb-4 bg-white/5 backdrop-blur-md rounded-[1.8rem] py-4 px-8 flex justify-between items-center group-hover:bg-f1-red/90 transition-all duration-500 border border-white/5">
                            <span class="text-[10px] font-black tracking-[0.2em] uppercase italic text-white/80 group-hover:text-white">Race Details</span>
                            <div class="bg-white/10 rounded-full p-1 group-hover:bg-white/20 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                                </svg>
                            </div>
                        </div>
                    </a>
                )
            })}
        </div>
    </main>
</Layout>

<style>
    .circuit-card {
        content-visibility: auto;
        contain-intrinsic-size: 1px 480px;
        backface-visibility: hidden;
        transform: translateZ(0);
    }

    .cubic-bezier {
        transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
    }

    img {
        aspect-ratio: 3 / 2;
    }

    /* Suavizado de bordes para fuentes en browsers Webkit */
    .font-f1-bold {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }
</style>